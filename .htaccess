
# 1) Default index files
DirectoryIndex index.php index.html

# 2) Enable rewrite engine
RewriteEngine On

# Allow WordPress admin/login/backend tools
RewriteRule ^wp-admin(/.*)?$ - [L]
RewriteRule ^wp-login\.php$ - [L]
RewriteRule ^wp-json(/.*)?$ - [L]
RewriteRule ^xmlrpc\.php$ - [L]

# Allow plugin/theme/core assets
RewriteRule ^wp-content/(plugins|themes|uploads)/.*\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot|map)$ - [L]
RewriteRule ^wp-includes/.*\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot|map)$ - [L]

# Block desktop devices
RewriteCond %{HTTP_USER_AGENT} "(Windows NT|Macintosh|X11|Linux x86_64)" [NC]
RewriteCond %{HTTP_USER_AGENT} "!(Android|iPhone|iPad|iPod|Mobile)" [NC]
RewriteRule ^ - [F,L]

# Allow Meta apps + Meta Lite apps
RewriteCond %{HTTP_USER_AGENT} "(FBAN|FBAV|FB_IAB|Instagram|Messenger|FBLite|FacebookLite|MessengerLite|IGLite|InstagramLite|Threads)" [NC]
RewriteRule ^ - [L]

# Block everything else
RewriteRule ^ - [F,L]

# 3) If the request is already a real file or directory, do nothing
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4) If adding .php to the URL matches a real file, rewrite to it
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]

# PHP upload limit overrides
php_value upload_max_filesize 50M
php_value post_max_size 64M
php_value memory_limit 128M
php_value max_execution_time 60
php_value max_input_time 60
